      "source": [
        "import numpy as np\n",
        "marks = np.array([4,8,6,5,7])\n",
        "\n",
        "#population ( divided by N)  ddof=0(default)\n",
        "print(np.var(marks))\n",
        "print(np.std(marks))\n",
        "\n",
        "#sample(divided by n-1)\n",
        "print(np.var(marks,ddof=1))\n",
        "print(np.std(marks,ddof=1))"
      ]
    }
  ]

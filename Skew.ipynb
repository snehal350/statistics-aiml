      "source": [
        "from scipy.stats import skew\n",
        "import numpy as np\n",
        "\n",
        "income = np.array([22, 25, 40, 95, 27, 28, 30, 31, 33, 35])\n",
        "\n",
        "print(f\"Mean = {income.mean():.1f}\")\n",
        "print(f\"Median = {np.median(income):.1f}\")\n",
        "print(f\"Skew = {skew(income):.2f}\")"
      ]
    }
  ]

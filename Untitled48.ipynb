      "source": [
        "import numpy as np\n",
        "Scores = np.array([3,5,7,8,12,13,14,18,21])\n",
        "\n",
        "#Range\n",
        "data_range = Scores.max() - Scores.min()\n",
        "\n",
        "#Quartiles & IQR\n",
        "q1 = np.percentile(Scores,25)\n",
        "q3 = np.percentile(Scores,75)\n",
        "iqr = q3-q1\n",
        "\n",
        "print(f\"Range = {data_range}\")\n",
        "print(f\"Q1= {q1}, Q3= {q3}, IQR= {iqr}\")\n"
      ]
    }
  ]
}